{
  "name": "@template/web",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/api/index.ts"
  },
  "scripts": {
    "build": "vite build && esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js --format=esm --external:pg --external:better-auth --external:hono --external:drizzle-orm --external:resend --external:dodopayments --external:standardwebhooks --external:zod",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "db:generate": "dotenv -e ../../.env -- npx drizzle-kit generate",
    "db:pull": "dotenv -e ../../.env -- npx drizzle-kit pull",
    "db:migrate": "dotenv -e ../../.env -- npx drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env -- npx drizzle-kit push",
    "db:studio": "dotenv -e ../../.env -- npx drizzle-kit studio"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@runablehq/website-runtime": "^0.10.0",
    "@tanstack/react-query": "^5.100.6",
    "@types/pg": "8.20.0",
    "better-auth": "1.4.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dodopayments": "^2.31.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "lucide-react": "^0.577.0",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "resend": "^6.12.3",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.3.5",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "@vitejs/plugin-react": "5.1.4",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  }
}
