{
  "name": "sandbox-app-template",
  "private": true,
  "packageManager": "npm@1.3.5",
  "workspaces": [
    "packages/web",
    "packages/mobile"
  ],
  "scripts": {
    "dev": "cd packages/web && npx vite",
    "dev:desktop": "cd packages/desktop && npx vite",
    "dev:mobile": "cd packages/mobile && npx expo start",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:pull": "turbo db:pull",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio"
  },
  "devDependencies": {
    "@tursodatabase/api": "^1.9.2",
    "@types/npm": "latest",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@libsql/client": "^0.17.2",
    "bigint-buffer": "1.1.5",
    "cloudflare": "^5.2.0",
    "dotenv-cli": "11.0.0",
    "expo": "55.0.23"
  }
}
